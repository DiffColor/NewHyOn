<Window x:Class="NewHyOn.Settings.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NewHyOn.Settings.Wpf"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid ClipToBounds="True">

        <Border Width="475"
                Height="442"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="#FCFDFE"
                BorderBrush="#D9E0E6"
                BorderThickness="1"
                CornerRadius="18">
            <Border.Effect>
                <DropShadowEffect BlurRadius="42"
                                  ShadowDepth="18"
                                  Direction="270"
                                  Opacity="0.06"
                                  Color="#0F172A" />
            </Border.Effect>

            <Canvas>
                <Border Width="473"
                        Height="34"
                        Background="#F8FAFC"
                        BorderBrush="#E5EBF0"
                        BorderThickness="0,0,0,1"
                        CornerRadius="18,18,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                    <Grid Margin="12,0,12,0"
                          Background="Transparent"
                          MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Style="{StaticResource TrafficCloseButton}"
                                    Click="CloseButton_OnClick" />
                            <Button Margin="8,0,0,0"
                                    Style="{StaticResource TrafficMinimizeButton}"
                                    Click="MinimizeButton_OnClick" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Width="438"
                      Canvas.Left="16"
                      Canvas.Top="48"
                      MouseLeftButtonDown="HeaderDragArea_OnMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="NewHyOn"
                                   FontFamily="Segoe UI"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#12202F" />
                        <TextBlock Text="Settings Console"
                                   FontFamily="Segoe UI"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="#6B7C8C" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="ShowIpButton"
                                Style="{StaticResource GhostActionButton}"
                                Margin="0,0,8,0"
                                Content="IP 확인"
                                Click="ShowIpButton_OnClick" />
                        <Button x:Name="SaveButton"
                                Style="{StaticResource PrimaryActionButton}"
                                Width="118"
                                Click="SaveButton_OnClick">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Grid x:Name="SaveButtonSpinner"
                                      Width="12"
                                      Height="12"
                                      Margin="0,0,6,0"
                                      Visibility="Collapsed">
                                    <Path Stroke="#7EE3EB"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M 10,6 A 4,4 0 1 1 6,2">
                                        <Path.RenderTransform>
                                            <RotateTransform x:Name="SaveButtonSpinnerRotateTransform"
                                                             CenterX="6"
                                                             CenterY="6" />
                                        </Path.RenderTransform>
                                    </Path>
                                </Grid>
                                <TextBlock x:Name="SaveButtonTextBlock"
                                           Text="저장"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Width="438"
                      Canvas.Left="16"
                      Canvas.Top="120">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="206" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Height="211"
                            Padding="14"
                            Background="#FFFFFF"
                            BorderBrush="#DCE3EA"
                            BorderThickness="1"
                            CornerRadius="12" Margin="0,0,0,66">
                        <StackPanel>
                            <TextBlock Text="서버 연결"
                                       FontFamily="Segoe UI"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#12202F" />

                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="데이터 서버 IP"
                                           FontFamily="Segoe UI"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#2B3F50" />
                                <Border Height="42"
                                        Margin="0,5,0,0"
                                        Padding="12,0"
                                        Background="#F8FAFC"
                                        BorderBrush="#D7DEE5"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <TextBox x:Name="DataServerIpTextBox" HorizontalContentAlignment="Center"
                                             Style="{StaticResource CompactInputTextBox}"
                                             Text="192.168.0.100" />
                                </Border>
                            </StackPanel>

                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="메시지 서버 IP"
                                           FontFamily="Segoe UI"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#2B3F50" />
                                <Border Height="42"
                                        Margin="0,5,0,0"
                                        Padding="12,0"
                                        Background="#F8FAFC"
                                        BorderBrush="#D7DEE5"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <TextBox x:Name="MessageServerIpTextBox"
                                             Style="{StaticResource CompactInputTextBox}" HorizontalContentAlignment="Center"
                                             Text="192.168.0.101" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="2">
                        <Border Padding="14"
                                Background="#FFFFFF"
                                BorderBrush="#DCE3EA"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Text="전송 설정"
                                           FontFamily="Segoe UI"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           Foreground="#12202F" />

                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="FTP Port"
                                               FontFamily="Segoe UI"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#2B3F50" />
                                    <Border Height="42"
                                            Margin="0,7,0,0"
                                            Padding="12,0"
                                            Background="#F8FAFC"
                                            BorderBrush="#D7DEE5"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <TextBox x:Name="FtpPortTextBox"
                                                 Style="{StaticResource CompactInputTextBox}" HorizontalContentAlignment="Center"
                                                 Text="2100" />
                                    </Border>
                                </StackPanel>

                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="패시브 포트 범위"
                                               FontFamily="Segoe UI"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#2B3F50" />
                                    <Grid Width="186"
                                          Margin="0,7,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="26" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>

                                        <Border Height="42"
                                                Padding="12,0"
                                                Background="#F8FAFC"
                                                BorderBrush="#D7DEE5"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <TextBox x:Name="PasvMinPortTextBox"
                                                     Style="{StaticResource CompactInputTextBox}" HorizontalContentAlignment="Center"
                                                     Text="50000" />
                                        </Border>

                                        <TextBlock Grid.Column="1"
                                                   Text="~"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Segoe UI"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#8695A3" />

                                        <Border Grid.Column="2"
                                                Height="42"
                                                Padding="12,0"
                                                Background="#F8FAFC"
                                                BorderBrush="#D7DEE5"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <TextBox x:Name="PasvMaxPortTextBox"
                                                     Style="{StaticResource CompactInputTextBox}" HorizontalContentAlignment="Center"
                                                     Text="50100" />
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="FTP Root Path"
                                               FontFamily="Segoe UI"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#2B3F50" />
                                    <Border Height="42"
                                            Margin="0,7,0,0"
                                            Padding="12,0"
                                            Background="#F8FAFC"
                                            BorderBrush="#D7DEE5"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <TextBox x:Name="FtpRootPathTextBox"
                                                 Style="{StaticResource CompactInputTextBox}" HorizontalContentAlignment="Center"
                                                 Text="/NewHyOn/contents" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Width="206"
                        Canvas.Left="16"
                        Canvas.Top="343"
                        Padding="14"
                        Background="#FFFFFF"
                        BorderBrush="#DCE3EA"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="컨텐츠 비율대로 표시"
                                   VerticalAlignment="Center"
                                   FontFamily="Inter, Segoe UI"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#2B3F50" />
                        <CheckBox x:Name="PreserveAspectRatioCheckBox"
                                  Grid.Column="1"
                                  Style="{StaticResource CompactToggleCheckBox}"
                                  IsChecked="True" />
                    </Grid>
                </Border>
            </Canvas>
        </Border>

        <Border x:Name="DialogOverlay"
                Width="475"
                Height="442"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="#660F172A"
                CornerRadius="18"
                Panel.ZIndex="100"
                Visibility="Collapsed"
                IsHitTestVisible="False" />
    </Grid>
</Window>

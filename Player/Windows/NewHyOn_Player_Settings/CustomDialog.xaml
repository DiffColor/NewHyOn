<Window x:Class="NewHyOn.Player.Settings.CustomDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Border Width="380"
            MinHeight="220"
            Background="#FCFDFE"
            BorderBrush="#D9E0E6"
            BorderThickness="1"
            CornerRadius="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32"
                              ShadowDepth="16"
                              Direction="270"
                              Opacity="0.18"
                              Color="#020617" />
        </Border.Effect>
        <Grid>
            <Border Height="34"
                    VerticalAlignment="Top"
                    Background="#F8FAFC"
                    BorderBrush="#E5EBF0"
                    BorderThickness="0,0,0,1"
                    CornerRadius="20,20,0,0"
                    MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid Margin="12,0,12,0"
                      Background="Transparent"
                      MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource TrafficCloseButton}"
                                Click="CloseButton_OnClick" />
                        <Button Margin="8,0,0,0"
                                Style="{StaticResource TrafficMinimizeButton}"
                                Click="DecorationButton_OnClick" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Margin="22,54,22,22">
                <TextBlock x:Name="DialogTitleTextBlock"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#12202F" />
                <TextBlock x:Name="DialogSubtitleTextBlock"
                           Margin="0,6,0,0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#177E89" />
                <Border Margin="0,18,0,0"
                        Padding="16"
                        Background="#F8FAFC"
                        BorderBrush="#E2EAF0"
                        BorderThickness="1"
                        CornerRadius="14">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  MaxHeight="180">
                        <TextBlock x:Name="DialogMessageTextBlock"
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Foreground="#43596B" />
                    </ScrollViewer>
                </Border>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,18,0,0">
                    <Button x:Name="SecondaryActionButton"
                            Margin="0,0,8,0"
                            Style="{StaticResource DialogSecondaryButton}"
                            Visibility="Collapsed"
                            Content="닫기"
                            Click="SecondaryButton_OnClick" />
                    <Button x:Name="PrimaryActionButton"
                            Width="96"
                            Style="{StaticResource DialogPrimaryButton}"
                            Content="확인"
                            Click="PrimaryButton_OnClick" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
